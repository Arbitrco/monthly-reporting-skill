#!/usr/bin/env python3
"""Rasterise a PDF to per-page JPEGs for visual QA.

Wraps pdftoppm. Output filenames are <prefix>-1.jpg, <prefix>-2.jpg, etc.

Usage:
    python qa_pages.py --pdf report.pdf --out qa/ --dpi 150
"""

import argparse
import shutil
import subprocess
import sys
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--pdf", required=True, help="Source PDF")
    parser.add_argument("--out", default="qa", help="Output directory (default: qa/)")
    parser.add_argument("--dpi", type=int, default=150, help="Resolution in DPI (default: 150)")
    parser.add_argument("--prefix", default="page", help="Filename prefix (default: page)")
    args = parser.parse_args()

    if not shutil.which("pdftoppm"):
        print(
            "error: pdftoppm not found. Install with:\n"
            "  apt-get install -y poppler-utils",
            file=sys.stderr,
        )
        return 2

    pdf_path = Path(args.pdf)
    if not pdf_path.exists():
        print(f"error: {pdf_path} not found", file=sys.stderr)
        return 1

    out_dir = Path(args.out)
    out_dir.mkdir(parents=True, exist_ok=True)

    out_prefix = out_dir / args.prefix
    cmd = [
        "pdftoppm",
        "-jpeg",
        "-r",
        str(args.dpi),
        str(pdf_path),
        str(out_prefix),
    ]
    result = subprocess.run(cmd, check=False)
    if result.returncode != 0:
        print(f"error: pdftoppm exited with {result.returncode}", file=sys.stderr)
        return result.returncode

    rendered = sorted(out_dir.glob(f"{args.prefix}-*.jpg"))
    print(f"rendered {len(rendered)} page(s) to {out_dir}/")
    for p in rendered:
        print(f"  {p}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
