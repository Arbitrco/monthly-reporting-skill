#!/usr/bin/env python3
"""Assemble the monthly operational report HTML + PDF for a given period.

Generalised from a production monthly operational report assembler.

Reads:
    {reports_dir}/{period}-report-inputs.json
        - period, period_label, issued, data_as_at
        - insights[]:        {kind:'decision'|'insight', label, text}
        - cross_team_asks[]: {dept, request, by_when}
        - action_items[]:    {owner, action, by_when}
    {reports_dir}/fragments/{period}-section-{N}.html  for each section

Writes:
    {reports_dir}/{period}-{report-slug}.html
    {reports_dir}/{period}-{report-slug}.pdf
    {reports_dir}/{period}-report-actions.json   (carry-forward state for next month)

The report-slug is derived from brand.report.title in your brand.json
(lowercased, non-alphanumeric collapsed to hyphens). For example, with the
default title "Monthly Operational Report" the output is
"2026-04-monthly-operational-report.html". Override with --out-html and
--out-pdf if you need a different name.

Brand:
    Pass --brand-json PATH to load colours/fonts/title from a brand config file.
    If not given, sensible neutral defaults are used.
    The logo is loaded from brand.company.logo_path if present; otherwise a
    text-only fallback is rendered in place of the logo box.

Usage:
    python assemble_report.py --period 2026-04
    python assemble_report.py --period 2026-04 --brand-json brand.json \\
        --issued "20 May 2026" --data-as-at "20 May 2026"
"""

import argparse
import base64
import copy
import html
import json
import mimetypes
import os
import re
import sys
from datetime import date
from pathlib import Path


def esc(value):
    """HTML-escape a user-derived value for safe insertion into the report.

    Applied to everything authored by a human (insights, cross-team asks,
    action items) and to brand strings (company name, url) so that
    characters like <, > and & render literally instead of being parsed as
    markup. Structural entities the assembler emits itself (&mdash;,
    &middot;) are written outside this call and are never double-escaped.
    quote=True so the same helper is safe in attribute contexts (alt="...").
    """
    return html.escape("" if value is None else str(value))


MONTH_NAMES = ["", "January", "February", "March", "April", "May", "June",
               "July", "August", "September", "October", "November", "December"]


