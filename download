def build_actions_json(period_label, cross_team, actions):
    today = date.today().strftime("%Y-%m-%d")
    return {
        "period":          period_label,
        "generated":       today,
        "cross_team_asks": [
            {"dept":    a.get("dept", ""),
             "request": a.get("request", ""),
             "by_when": a.get("by_when", ""),
             "status":  "open"}
            for a in cross_team
        ],
        "action_items": [
            {"owner":   a.get("owner", ""),
             "action":  a.get("action", ""),
             "by_when": a.get("by_when", ""),
             "status":  "open"}
            for a in actions
        ],
    }


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

DEFAULT_EMPTY_CROSS_TEAM = (
    "No cross-team asks have been raised this month. "
    "Outstanding items from prior reports remain in their respective owners' workstreams."
)
DEFAULT_EMPTY_ACTIONS = (
    "No new action items have been raised from this month's results. "
    "Decisions flagged in the insights section carry their own owners; "
    "standing operational tasks remain in the team trackers."
)


def main():
    args = parse_args()

    year, month, period_short, period_label = parse_period(args.period)
    today = date.today()
    issued_default = today.strftime("%d %B %Y").lstrip("0")

    # Brand — loaded early so the report-title slug can drive default output filenames
    brand = load_brand(args.brand_json)
    logo_uri = load_logo_data_uri(brand["company"].get("logo_path"))
    logo_box = logo_box_html(logo_uri, brand["company"]["name"], brand)
    report_slug = slugify_report_title(brand["report"].get("title", ""))

    # Resolve paths
    reports_dir   = Path(args.reports_dir)
    fragments_dir = Path(args.fragments_dir) if args.fragments_dir else reports_dir / "fragments"
    inputs_path   = Path(args.inputs) if args.inputs else reports_dir / f"{args.period}-report-inputs.json"
    out_html      = Path(args.out_html) if args.out_html else reports_dir / f"{args.period}-{report_slug}.html"
    out_pdf       = Path(args.out_pdf) if args.out_pdf else reports_dir / f"{args.period}-{report_slug}.pdf"
    out_actions   = Path(args.out_actions) if args.out_actions else reports_dir / f"{args.period}-report-actions.json"

    # Inputs JSON
    if not inputs_path.exists():
        raise SystemExit(
            f"Inputs file not found: {inputs_path}\n"
            f"Create one with the schema:\n"
            f'{{"period":"{args.period}","period_label":"{period_label}",'
            f'"issued":"...","data_as_at":"...",'
            f'"insights":[...],"cross_team_asks":[...],"action_items":[...]}}'
        )
    inputs = json.loads(inputs_path.read_text(encoding="utf-8"))
    period_label  = inputs.get("period_label", period_label)
    issued        = args.issued     or inputs.get("issued")     or issued_default
    data_as_at    = args.data_as_at or inputs.get("data_as_at") or issued
    insights      = inputs.get("insights", [])
    cross_team    = inputs.get("cross_team_asks", [])
    actions       = inputs.get("action_items", [])

    empty_cross_team = args.empty_cross_team or DEFAULT_EMPTY_CROSS_TEAM
    empty_actions    = args.empty_actions    or DEFAULT_EMPTY_ACTIONS

    # Discover section fragments by globbing fragments_dir
    fragment_pattern = re.compile(rf"^{re.escape(args.period)}-section-(\d+)\.html$")
    fragment_paths = sorted(
        (p for p in fragments_dir.glob(f"{args.period}-section-*.html")
         if fragment_pattern.match(p.name)),
        key=lambda p: int(fragment_pattern.match(p.name).group(1)),
    )
    if not fragment_paths:
        print(f"warning: no fragment files found in {fragments_dir}",
              file=sys.stderr)
    fragment_numbers = [int(fragment_pattern.match(p.name).group(1))
                        for p in fragment_paths]

    # Section 1 is reserved for the Key Insights front section. A data section
    # numbered 1 would render a second "1." heading; warn rather than silently
    # produce a confusing report. (DOM ids no longer collide — the inline
    # sections use stable string ids — but the visible numbering still would.)
    if 1 in fragment_numbers:
        print("warning: a data section is numbered 1, which is reserved for "
              "Key Insights. Renumber it (data sections should start at 2) to "
              "avoid two '1.' headings.", file=sys.stderr)

    # Build fragment HTML blocks
    fragment_blocks = []
    for n, p in zip(fragment_numbers, fragment_paths):
        content = p.read_text(encoding="utf-8")
        normalised = normalise_fragment(content, logo_box)
        fragment_blocks.append(
            f'<div class="page-content" style="page-break-before:always">\n'
            f'{normalised}\n</div>'
        )

    # Section numbering for inline sections
    # Insights = 1, Cross-Team Asks = max_fragment_n + 1, Action Items = +2
    insights_n = 1
    if fragment_numbers:
        next_after_fragments = max(fragment_numbers) + 1
    else:
        next_after_fragments = 9
    cross_team_n = next_after_fragments
    actions_n    = next_after_fragments + 1

    # Build inline sections
    insights_html = build_insights_section(insights_n, insights, logo_box, brand)
    cross_team_rows = [(a.get("dept", ""), a.get("request", ""), a.get("by_when", ""))
                       for a in cross_team]
    cross_team_html = build_table_section(
        cross_team_n, "Cross-Team Asks",
        columns=["Department", "Request", "By When"],
        widths=[20, 60, 20],
        rows=cross_team_rows,
        empty_text=empty_cross_team,
        logo_box=logo_box, brand=brand, dom_id="section-cross-team",
    )
    actions_rows = [(a.get("owner", ""), a.get("action", ""), a.get("by_when", ""))
                    for a in actions]
    actions_html = build_table_section(
        actions_n, "Action Items",
        columns=["Owner", "Action", "By When"],
        widths=[15, 65, 20],
        rows=actions_rows,
        empty_text=empty_actions,
        logo_box=logo_box, brand=brand, dom_id="section-actions",
    )

    # Cover
    cover_html = build_cover(brand, period_label, issued, data_as_at, logo_uri)

    # Outer document
    brand_css = build_brand_css(brand)
    conf_text = brand["company"].get("confidentiality_text")
    if conf_text:
        confidentiality = esc(conf_text)
    else:
        confidentiality = (
            f'Confidential &middot; {esc(brand["company"]["name"])} &middot; {year}'
        )

    doc_title = f'{esc(brand["report"]["title"].upper())} &mdash; {esc(period_label.upper())}'
    full_html = (
        '<!DOCTYPE html>\n<html lang="en">\n<head>\n'
        '<meta charset="UTF-8">\n'
        f'<title>{doc_title}</title>\n'
        f'<link href="{esc(brand["typography"].get("google_fonts_url",""))}" rel="stylesheet">\n'
        f'<style>{brand_css}</style>\n'
        '</head>\n<body>\n'
        + cover_html + "\n"
        + insights_html + "\n"
        + "\n".join(fragment_blocks) + ("\n" if fragment_blocks else "")
        + cross_team_html + "\n"
        + actions_html + "\n"
        + f'<div id="global-footer">\n'
        f'  <span class="gf-left">{confidentiality}</span>\n'
        f'  <span class="gf-right">{esc(brand["company"]["url"])}</span>\n'
        f'</div>\n'
        '</body>\n</html>'
    )

    out_html.parent.mkdir(parents=True, exist_ok=True)
    out_html.write_text(full_html, encoding="utf-8")
    print(f"HTML saved: {out_html} ({len(full_html):,} chars)")

    # Carry-forward actions JSON
    actions_data = build_actions_json(period_label, cross_team, actions)
    out_actions.parent.mkdir(parents=True, exist_ok=True)
    out_actions.write_text(
        json.dumps(actions_data, indent=2, ensure_ascii=False),
        encoding="utf-8",
    )
    print(f"Actions JSON saved: {out_actions}")

    # PDF
    try:
        from weasyprint import HTML as WPH  # type: ignore
        WPH(filename=str(out_html), base_url=str(out_html.parent)).write_pdf(str(out_pdf))
        print(f"PDF saved: {out_pdf} ({os.path.getsize(out_pdf):,} bytes)")
    except ImportError:
        print("WeasyPrint not installed — HTML only. Install with:\n"
              "  pip install -r requirements.txt", file=sys.stderr)
    except Exception as e:
        print(f"WeasyPrint error: {e}", file=sys.stderr)


if __name__ == "__main__":
    main()
