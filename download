def page_open(section_n, title, logo_box, brand, dom_id=None):
    c = brand["colours"]
    element_id = dom_id or f"section-{section_n}"
    return (
        f'<div id="{element_id}" class="page-content" '
        f'style="font-family:\'{brand["typography"]["font_family"]}\','
        f'{brand["typography"]["font_fallback"]};background:{c["bg_page"]};'
        f'width:8.5in;box-sizing:border-box;page-break-before:always">\n'
        f'  <div class="shb" style="background:{c["primary"]};padding:0 48px;'
        f'height:56px;display:flex;justify-content:space-between;align-items:center">\n'
        f'    <h2 style="font-size:13pt;font-weight:800;color:#fff;margin:0;'
        f'letter-spacing:1px;text-transform:uppercase">{section_n}. {esc(title)}</h2>\n'
        f'    {logo_box}\n'
        f'  </div>\n'
        f'  <div style="padding:28px 48px 36px">\n'
    )


def page_close():
    return "  </div>\n</div>"


def build_insights_section(section_n, insights, logo_box, brand):
    """Section 1 (or wherever) — Key Insights and Decisions Required."""
    c = brand["colours"]
    items = []
    for ins in insights:
        kind  = ins.get("kind", "insight")
        label = esc(ins.get("label", ""))
        text  = esc(ins.get("text", ""))
        if kind == "decision":
            tag    = "Decision Required &mdash; " + label
            border = c["alert"]
            bg     = "#FDF3EE"
            color  = c["alert"]
        else:
            tag    = label
            border = c["accent"]
            bg     = "#F0F7FC"
            color  = c["primary"]
        items.append(
            f'      <li style="padding:12px 14px;margin-bottom:10px;border-radius:8px;'
            f'border-left:4px solid {border};background:{bg};font-size:9.5pt;'
            f'color:{c["text"]};line-height:1.6">'
            f'<span style="font-weight:800;color:{color};text-transform:uppercase;'
            f'font-size:8pt;margin-right:6px">{tag}:</span>{text}</li>'
        )
    return (
        page_open(section_n, "Key Insights and Decisions Required", logo_box, brand,
                  dom_id="section-insights")
        + '    <ul style="list-style:none;padding:0;margin:0">\n'
        + "\n".join(items)
        + "\n    </ul>\n"
        + page_close()
    )


def build_table_section(section_n, title, columns, widths, rows, empty_text,
                        logo_box, brand, dom_id=None):
    c = brand["colours"]
    headers = "".join(
        f'<th style="padding:8px 12px;background:{c["primary"]};color:#fff;'
        f'font-weight:700;text-transform:uppercase;font-size:7pt;text-align:left;'
        f'width:{w}%">{col}</th>'
        for col, w in zip(columns, widths)
    )
    if not rows:
        body = (
            f'    <div style="background:#fff;border-radius:8px;'
            f'box-shadow:0 2px 8px rgba(0,0,0,.07);padding:24px 28px;text-align:center">'
            f'<p style="font-size:9.5pt;color:{c["text"]};margin:0;line-height:1.5">'
            f'{empty_text}</p></div>'
        )
    else:
        tr_html = []
        for i, r in enumerate(rows):
            bg = c["bg_page"] if i % 2 == 0 else "#fff"
            tds = "".join(
                f'<td style="padding:8px 12px;'
                f'color:{(c["primary"] + ";font-weight:700") if k == 0 else c["text"]};'
                f'border-bottom:1px solid {c["border"]}">{esc(v)}</td>'
                for k, v in enumerate(r)
            )
            tr_html.append(f'<tr style="background:{bg}">{tds}</tr>')
        body = (
            '    <div style="background:#fff;border-radius:8px;'
            'box-shadow:0 2px 8px rgba(0,0,0,.07);overflow:hidden">'
            '<table style="width:100%;border-collapse:collapse;font-size:8pt">'
            f'<thead><tr>{headers}</tr></thead>'
            f'<tbody>{"".join(tr_html)}</tbody>'
            '</table></div>'
        )
    return page_open(section_n, title, logo_box, brand, dom_id=dom_id) + body + "\n" + page_close()


