def load_logo_data_uri(logo_path):
    """Return a base64 data URI for the logo with the correct MIME type.

    Derives the media type from the file extension (PNG, JPG, SVG, GIF,
    WEBP all supported by WeasyPrint) rather than assuming JPEG. Missing
    path -> None (callers fall back to a text badge).
    """
    if not logo_path:
        return None
    p = Path(logo_path)
    if not p.exists():
        print(f"warning: logo path {logo_path} not found; using text fallback",
              file=sys.stderr)
        return None
    mime, _ = mimetypes.guess_type(str(p))
    if not mime or not mime.startswith("image/"):
        ext = p.suffix.lower().lstrip(".")
        mime = {
            "svg": "image/svg+xml", "jpg": "image/jpeg", "jpeg": "image/jpeg",
            "png": "image/png", "gif": "image/gif", "webp": "image/webp",
        }.get(ext, "image/png")
    b64 = base64.b64encode(p.read_bytes()).decode("ascii")
    return f"data:{mime};base64,{b64}"


