    return f'<span style="font-weight:800;color:{primary}">{esc(company_name)}</span>'


# ---------------------------------------------------------------------------
# Fragment normaliser
# ---------------------------------------------------------------------------

_DOCTYPE_RE = re.compile(
    r'<!DOCTYPE[^>]*>\s*<html[^>]*>.*?<head>(?P<head>.*?)</head>\s*<body[^>]*>(?P<body>.*)</body>\s*</html>',
    re.S,
)
_STYLE_RE = re.compile(r'<style[^>]*>.*?</style>', re.S)
_SHM_BLOCK_RE = re.compile(
    r'<div class="shm">\s*<div class="mp">[^<]*</div>\s*<div class="mr">[^<]*</div>\s*</div>',
    re.S,
)
_SHB_PADDING_RE = re.compile(r'(#section-\d+ \.shb\{background:[#A-Fa-f0-9]+;)padding:14px 48px;')

_HEADER_OPENERS = (
    re.compile(r'<div class="shb">', re.S),
    re.compile(r'<div class="header-band">', re.S),
    re.compile(r'<header class="header-band">', re.S),
)


def inject_logo_into_header(html, logo_box):
    """Insert .shl logo box before the closing tag of the first header bar.
    Nesting-aware; idempotent if a .shl already exists."""
    if 'class="shl"' in html:
        return html
    for opener in _HEADER_OPENERS:
        match = opener.search(html)
        if not match:
            continue
        i = match.end()
        is_header_tag = match.group(0).startswith("<header")
        close_tag = "</header>" if is_header_tag else "</div>"
        open_tag  = "<header"   if is_header_tag else "<div"
        depth = 1
        n = len(html)
        while i < n and depth > 0:
            j_close = html.find(close_tag, i)
            j_open  = html.find(open_tag, i)
            if j_close == -1:
                break
            if j_open != -1 and j_open < j_close:
                depth += 1
                i = j_open + len(open_tag)
            else:
                depth -= 1
                i = j_close + len(close_tag)
        if depth != 0:
            return html  # unbalanced, leave alone
        insert_at = i - len(close_tag)
        return html[:insert_at].rstrip() + "\n  " + logo_box + "\n" + html[insert_at:]
    return html


def normalise_fragment(html, logo_box):
    """Make fragments produced by varying section renderers assemble cleanly."""
    doc = _DOCTYPE_RE.search(html)
    if doc:
        head_styles = "\n".join(_STYLE_RE.findall(doc.group("head")))
        html = (head_styles + "\n" + doc.group("body")) if head_styles else doc.group("body")
    html = _SHM_BLOCK_RE.sub("", html)
    html = _SHB_PADDING_RE.sub(r"\1padding:0 48px;height:56px;", html)
    html = inject_logo_into_header(html, logo_box)
    return html


