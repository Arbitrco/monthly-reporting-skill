def deep_merge(base, override):
    """Merge override into base, recursing into dicts."""
    out = dict(base)
    for k, v in override.items():
        if k in out and isinstance(out[k], dict) and isinstance(v, dict):
            out[k] = deep_merge(out[k], v)
        else:
            out[k] = v
    return out


def load_brand(path):
    """Load brand.json and merge over defaults. Missing path -> defaults."""
    brand = copy.deepcopy(DEFAULT_BRAND)
    if path and Path(path).exists():
        loaded = json.loads(Path(path).read_text(encoding="utf-8"))
        brand = deep_merge(DEFAULT_BRAND, loaded)
    return brand


def slugify_report_title(title):
    """Turn a report title into a filename-safe slug.

    "Monthly Operational Report" -> "monthly-operational-report"
    "Q3 Sales & Marketing Update" -> "q3-sales-marketing-update"
    "" -> "report"  (fallback so we never emit an empty filename)
    """
    if not title:
        return "report"
    s = title.lower()
    # Replace any run of non-alphanumeric chars with a single hyphen
    s = re.sub(r"[^a-z0-9]+", "-", s)
    # Strip leading/trailing hyphens
    s = s.strip("-")
    return s or "report"


