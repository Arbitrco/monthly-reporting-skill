def parse_args():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--period", required=True,
                    help="Reporting period in YYYY-MM form (e.g. 2026-04)")
    ap.add_argument("--issued", default=None,
                    help="Issued date string (e.g. '20 May 2026'). Defaults to today.")
    ap.add_argument("--data-as-at", default=None,
                    help="Data-as-at date string. Defaults to issued.")
    ap.add_argument("--brand-json", default=None,
                    help="Path to brand.json (optional). Falls back to neutral defaults.")
    ap.add_argument("--reports-dir", default="reports",
                    help="Reports directory (default: reports/)")
    ap.add_argument("--fragments-dir", default=None,
                    help="Fragments directory (default: <reports-dir>/fragments)")
    ap.add_argument("--inputs", default=None,
                    help="Inputs JSON path (default: <reports-dir>/<period>-report-inputs.json)")
    ap.add_argument("--out-html", default=None,
                    help="Output HTML path")
    ap.add_argument("--out-pdf", default=None,
                    help="Output PDF path")
    ap.add_argument("--out-actions", default=None,
                    help="Output actions JSON path")
    ap.add_argument("--empty-cross-team", default=None,
                    help="Empty-state text for Cross-Team Asks")
    ap.add_argument("--empty-actions", default=None,
                    help="Empty-state text for Action Items")
    return ap.parse_args()


# ---------------------------------------------------------------------------
# Period parsing
# ---------------------------------------------------------------------------

def parse_period(period):
    m = re.match(r"^(\d{4})-(\d{2})$", period)
    if not m:
        raise SystemExit(f"Invalid --period {period!r}; expected YYYY-MM")
    year, month = int(m.group(1)), int(m.group(2))
    if not 1 <= month <= 12:
        raise SystemExit(f"Invalid --period {period!r}; month must be 01-12")
    period_short = f"{MONTH_NAMES[month][:3]} {year}"
    period_label = f"{MONTH_NAMES[month]} {year}"
    return year, month, period_short, period_label


